---
import { Menu, X } from "lucide-astro";
import { navLinks } from "../../data/navigation";
import Button from "../ui/Button.astro";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md shadow-sm">
  <nav class="container mx-auto px-4 lg:px-8 flex items-center justify-between h-16 lg:h-20">
    <a href="#inicio" class="text-2xl font-display tracking-wide">
      <span class="text-primary">Burger</span>
      <span class="text-dark">House</span>
    </a>

    <ul class="hidden lg:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-dark/70 hover:text-primary transition-colors duration-300 text-sm font-semibold uppercase tracking-wider"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden lg:flex items-center gap-3">
      <Button href="#reservas" variant="yellow">Ordenar Ahora</Button>
    </div>

    <button
      id="mobile-toggle"
      class="lg:hidden text-dark p-2"
      aria-label="Abrir menú"
    >
      <Menu id="icon-open" class="w-6 h-6" />
      <X id="icon-close" class="w-6 h-6 hidden" />
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-cream border-t border-warm-gray"
  >
    <ul class="container mx-auto px-4 py-4 flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-link block text-dark/70 hover:text-primary transition-colors duration-300 text-base font-semibold py-2"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <Button href="#reservas" variant="yellow" class="w-full text-center">
          Ordenar Ahora
        </Button>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
