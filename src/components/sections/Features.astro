---
import { features } from "../../data/features";
import SectionHeading from "../ui/SectionHeading.astro";
import FeatureCard from "../ui/FeatureCard.astro";
---

<section id="nosotros" class="bg-white py-20 lg:py-28">
  <div class="container mx-auto px-4 lg:px-8">
    <SectionHeading
      title="Por Que Elegirnos"
      subtitle="Cada detalle importa. Desde la seleccion de ingredientes hasta la coccion final, buscamos la perfeccion."
    />

    <div class="grid md:grid-cols-3 gap-8">
      {features.map((feature) => <FeatureCard feature={feature} />)}
    </div>
  </div>
</section>
