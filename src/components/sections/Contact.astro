---
import { Phone, MapPin, Clock } from "lucide-astro";
import { branches } from "../../data/branches";
---

<section id="encuentranos">
  <!-- Banner hero -->
  <div class="relative py-20 lg:py-28 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1466978913421-dad2ebd01d17?w=1920&h=600&fit=crop"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-dark/70"></div>
    <div class="relative container mx-auto px-4 lg:px-8 text-center" data-reveal="fade-up">
      <h2 class="font-display text-5xl md:text-6xl lg:text-7xl tracking-wide text-white mb-4">
        ENCUÉNTRANOS
      </h2>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        Visítanos en cualquiera de nuestras sucursales y vive la experiencia BurgerHouse.
      </p>
    </div>
  </div>

  <!-- Sucursales -->
  <div class="bg-cream py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 mb-12">
        {
          branches.map((branch, index) => (
            <div
              data-branch={branch.id}
              data-reveal="fade-up"
              data-reveal-delay={index * 120}
              role="button"
              tabindex="0"
              aria-pressed={index === 0 ? "true" : "false"}
              class:list={[
                "bg-white p-6 lg:p-8 rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 cursor-pointer border-2",
                index === 0 ? "border-primary" : "border-transparent",
              ]}
            >
              <h3 class="font-display text-2xl lg:text-3xl tracking-wide text-dark mb-5">
                {branch.name}
              </h3>

              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                    <MapPin class="w-5 h-5 text-primary" />
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-dark">Dirección</p>
                    <p class="text-text-secondary text-sm">{branch.address}</p>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                    <Phone class="w-5 h-5 text-primary" />
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-dark">Teléfono</p>
                    <p class="text-text-secondary text-sm">{branch.phone}</p>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                    <Clock class="w-5 h-5 text-primary" />
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-dark">Horario</p>
                    {branch.hours.map((h) => (
                      <p class="text-text-secondary text-sm">{h}</p>
                    ))}
                  </div>
                </div>
              </div>

              <div class="mt-6 pt-4 border-t border-gray-100 text-center">
                <span class="text-primary text-sm font-semibold tracking-wide uppercase">
                  Ver en mapa &darr;
                </span>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Mapa compartido -->
      <div class="rounded-2xl overflow-hidden shadow-md h-72 lg:h-96 bg-cream" data-reveal="zoom-in">
        <iframe
          id="branch-map"
          src={branches[0].mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de sucursal BurgerHouse"
        ></iframe>
      </div>

      <script
        is:inline
        type="application/json"
        id="branch-data"
        set:html={JSON.stringify(Object.fromEntries(branches.map((b) => [b.id, b.mapEmbedUrl])))}
      ></script>
    </div>
  </div>

  <!-- Formulario de contacto -->
  <div class="bg-dark py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8 max-w-2xl">
      <div class="text-center mb-10">
        <h3 class="font-display text-3xl md:text-4xl tracking-wide text-white mb-2">
          ESCRÍBENOS
        </h3>
        <p class="text-white/60">
          ¿Tienes alguna pregunta o quieres hacer una reserva? Completa el formulario y te responderemos a la brevedad.
        </p>
      </div>

      <form class="space-y-5">
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-white/80 mb-2">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Tu nombre"
              class="w-full px-5 py-3 rounded-lg border border-white/10 bg-white/5 text-white placeholder:text-white/40 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-white/80 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@email.com"
              class="w-full px-5 py-3 rounded-lg border border-white/10 bg-white/5 text-white placeholder:text-white/40 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-white/80 mb-2">Asunto</label>
          <input
            type="text"
            id="subject"
            name="subject"
            placeholder="Asunto"
            class="w-full px-5 py-3 rounded-lg border border-white/10 bg-white/5 text-white placeholder:text-white/40 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-white/80 mb-2">Mensaje</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Escribe tu mensaje..."
            class="w-full px-5 py-3 rounded-lg border border-white/10 bg-white/5 text-white placeholder:text-white/40 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-primary text-white py-4 rounded-full font-bold uppercase tracking-wider text-sm hover:bg-primary-hover transition-colors duration-300 cursor-pointer shadow-lg hover:shadow-xl"
        >
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>("[data-branch]");
  const mapIframe = document.getElementById("branch-map") as HTMLIFrameElement | null;
  const branchMaps: Record<string, string> = JSON.parse(
    document.getElementById("branch-data")?.textContent ?? "{}"
  );

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      cards.forEach((c) => {
        c.classList.remove("border-primary");
        c.classList.add("border-transparent");
        c.setAttribute("aria-pressed", "false");
      });

      card.classList.add("border-primary");
      card.classList.remove("border-transparent");
      card.setAttribute("aria-pressed", "true");

      const branchId = card.getAttribute("data-branch");
      if (branchId && branchMaps[branchId] && mapIframe) {
        mapIframe.src = branchMaps[branchId];
      }
    });

    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        card.click();
      }
    });
  });
</script>
