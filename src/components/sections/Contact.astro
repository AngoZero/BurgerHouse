---
import { Phone, MessageCircle, Mail, MapPin } from "lucide-astro";
import { businessInfo } from "../../data/navigation";
---

<section id="contacto">
  <!-- Banner hero -->
  <div class="relative py-20 lg:py-28 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1466978913421-dad2ebd01d17?w=1920&h=600&fit=crop"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-dark/70"></div>
    <div class="relative container mx-auto px-4 lg:px-8 text-center">
      <h2 class="font-display text-5xl md:text-6xl lg:text-7xl tracking-wide text-white mb-4">
        CONTÁCTANOS
      </h2>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        Tienes alguna pregunta o quieres hacer una reserva? Escribenos y te responderemos lo antes posible.
      </p>
    </div>
  </div>

  <!-- Contacto: tarjetas + formulario -->
  <div class="bg-white py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Columna izquierda: tarjetas de contacto + mapa -->
        <div>
          <div class="grid grid-cols-2 gap-6 mb-8">
            <!-- Telefono -->
            <div class="text-center p-6 rounded-2xl bg-cream hover:shadow-lg transition-shadow duration-300">
              <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <Phone class="w-7 h-7 text-primary" />
              </div>
              <h3 class="font-bold text-dark mb-1">Teléfono</h3>
              <p class="text-text-secondary text-sm">{businessInfo.phone}</p>
            </div>

            <!-- WhatsApp -->
            <div class="text-center p-6 rounded-2xl bg-cream hover:shadow-lg transition-shadow duration-300">
              <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <MessageCircle class="w-7 h-7 text-primary" />
              </div>
              <h3 class="font-bold text-dark mb-1">WhatsApp</h3>
              <p class="text-text-secondary text-sm">{businessInfo.phone}</p>
            </div>

            <!-- Email -->
            <div class="text-center p-6 rounded-2xl bg-cream hover:shadow-lg transition-shadow duration-300">
              <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <Mail class="w-7 h-7 text-primary" />
              </div>
              <h3 class="font-bold text-dark mb-1">Email</h3>
              <p class="text-text-secondary text-sm">{businessInfo.email}</p>
            </div>

            <!-- Direccion -->
            <div class="text-center p-6 rounded-2xl bg-cream hover:shadow-lg transition-shadow duration-300">
              <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <MapPin class="w-7 h-7 text-primary" />
              </div>
              <h3 class="font-bold text-dark mb-1">Ubicación</h3>
              <p class="text-text-secondary text-sm">{businessInfo.address}</p>
            </div>
          </div>

          <!-- Mapa -->
          <div class="rounded-2xl overflow-hidden shadow-md h-64 lg:h-72">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3329.6!2d-70.65!3d-33.44!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzPCsDI2JzI0LjAiUyA3MMKwMzknMDAuMCJX!5e0!3m2!1ses!2scl!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación BurgerHouse"
            ></iframe>
          </div>
        </div>

        <!-- Columna derecha: formulario -->
        <div>
          <h3 class="font-display text-3xl md:text-4xl tracking-wide text-dark mb-2">
            ESCRIBENOS
          </h3>
          <p class="text-text-secondary mb-8">
            Completa el formulario y nos pondremos en contacto contigo a la brevedad.
          </p>

          <form class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-dark mb-2">Nombre</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Tu nombre"
                class="w-full px-5 py-3 rounded-lg border border-gray-200 bg-light focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-dark mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="tu@email.com"
                class="w-full px-5 py-3 rounded-lg border border-gray-200 bg-light focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-dark mb-2">Asunto</label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="Asunto"
                class="w-full px-5 py-3 rounded-lg border border-gray-200 bg-light focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-dark mb-2">Mensaje</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Escribe tu mensaje..."
                class="w-full px-5 py-3 rounded-lg border border-gray-200 bg-light focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-primary text-white py-4 rounded-full font-bold uppercase tracking-wider text-sm hover:bg-primary-hover transition-colors duration-300 cursor-pointer shadow-lg hover:shadow-xl"
            >
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
