---
import { Instagram, Facebook } from "lucide-astro";
import { socialLinks } from "../../data/navigation";

const year = new Date().getFullYear();
---

<footer class="bg-dark border-t border-white/10 py-8">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <a href="#inicio" class="text-xl font-display tracking-wide">
        <span class="text-yellow">Burger</span>
        <span class="text-white">House</span>
      </a>

      <div class="flex items-center gap-3">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              aria-label={link.name}
              class="w-10 h-10 rounded-full bg-white/10 hover:bg-yellow flex items-center justify-center transition-colors duration-300 group"
            >
              {link.icon === "Instagram" && <Instagram class="w-5 h-5 text-white group-hover:text-dark" />}
              {link.icon === "Facebook" && <Facebook class="w-5 h-5 text-white group-hover:text-dark" />}
              {link.icon === "X" && (
                <svg class="w-5 h-5 text-white group-hover:text-dark" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              )}
              {link.icon === "TikTok" && (
                <svg class="w-5 h-5 text-white group-hover:text-dark" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.7a8.18 8.18 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.13z" />
                </svg>
              )}
            </a>
          ))
        }
      </div>

      <p class="text-text-muted text-sm">
        &copy; {year} BurgerHouse. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
