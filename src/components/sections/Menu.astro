---
import { menuItems } from "../../data/menu";
import SectionHeading from "../ui/SectionHeading.astro";
import MenuCard from "../ui/MenuCard.astro";
---

<section id="menu" class="bg-cream py-20 lg:py-28">
  <div class="container mx-auto px-4 lg:px-8">
    <SectionHeading
      title="Nuestro Menu"
      subtitle="Explora nuestra selección de hamburguesas artesanales, desde las clásicas hasta creaciones premium."
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {menuItems.map((item) => <MenuCard item={item} />)}
    </div>
  </div>
</section>
