---
import Button from "../ui/Button.astro";
import { businessInfo } from "../../data/navigation";
---

<section id="reservas" class="bg-dark py-20 lg:py-28 overflow-hidden">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <span class="inline-block text-yellow font-semibold text-sm tracking-widest uppercase mb-4">
          No Esperes Más
        </span>
        <h2 class="font-display text-5xl md:text-6xl lg:text-7xl tracking-wide text-white leading-[0.95] mb-6">
          ORDENA TU
          <span class="text-yellow">BURGER</span>
          FAVORITA
        </h2>
        <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
          Disfruta de nuestras hamburguesas artesanales con delivery a domicilio
          o reserva una mesa para vivir la experiencia completa.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button href="#contacto" variant="yellow">Contactanos</Button>
          <Button href={`tel:${businessInfo.phone.replace(/\s/g, "")}`} variant="outline">
            Llamar Ahora
          </Button>
        </div>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-yellow/10 rounded-full blur-3xl"></div>
        <img
          src="/images/burger-bestia.png"
          alt="Hamburguesa artesanal"
          loading="lazy"
          decoding="async"
          class="relative w-full max-w-md lg:max-w-lg drop-shadow-2xl hover:scale-110 transition-transform duration-500"
        />
      </div>
    </div>
  </div>
</section>
