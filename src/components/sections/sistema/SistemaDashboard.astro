---
import {
  LayoutDashboard,
  Store,
  ReceiptText,
  CircleDollarSign,
  Building2,
  Package,
  Tag,
  Boxes,
  ChartNoAxesColumn,
  Users,
  Building,
  Flame,
  DollarSign,
  Receipt,
  TrendingUp,
  Vault,
  Smartphone,
  Wifi,
  Battery,
  Signal,
  Search,
  ShoppingCart,
  Bell,
  ChevronDown,
  Sun,
  Moon,
  Plus,
  Download,
  Pencil,
  Trash2,
  ArrowUpRight,
  ArrowDownRight,
  Filter,
  MoreVertical,
} from "lucide-astro";
import SectionHeading from "../../ui/SectionHeading.astro";

interface NavItem {
  id: string;
  title: string;
  icon: typeof LayoutDashboard;
}
interface NavSection {
  title: string;
  items: NavItem[];
}

const navSections: NavSection[] = [
  {
    title: "Operación",
    items: [
      { id: "dashboard", title: "Dashboard", icon: LayoutDashboard },
      { id: "pos", title: "Punto de venta", icon: Store },
      { id: "sales", title: "Ventas", icon: ReceiptText },
      { id: "cash", title: "Caja", icon: CircleDollarSign },
    ],
  },
  {
    title: "Catálogo",
    items: [
      { id: "branches", title: "Sucursales", icon: Building2 },
      { id: "products", title: "Productos", icon: Package },
      { id: "categories", title: "Categorías", icon: Tag },
      { id: "inventory", title: "Inventario", icon: Boxes },
    ],
  },
  {
    title: "Análisis",
    items: [{ id: "reports", title: "Reportes", icon: ChartNoAxesColumn }],
  },
  {
    title: "Administración",
    items: [
      { id: "users", title: "Usuarios", icon: Users },
      { id: "company", title: "Empresa", icon: Building },
    ],
  },
];

// --- Dashboard panel data ---
const statCards = [
  { icon: DollarSign, label: "Ventas hoy", value: 12450, prefix: "$", decimals: 0, change: "+18%", color: "text-emerald-500" },
  { icon: Receipt, label: "Tickets", value: 47, change: "+12%", color: "text-blue-500" },
  { icon: TrendingUp, label: "Ticket prom.", value: 264.89, prefix: "$", decimals: 2, change: "+5%", color: "text-yellow-dark" },
  { icon: Vault, label: "Cajas abiertas", value: 3, color: "text-primary" },
];
const chartDays = [
  { day: "Lun", value: 65 },
  { day: "Mar", value: 45 },
  { day: "Mié", value: 78 },
  { day: "Jue", value: 55 },
  { day: "Vie", value: 90 },
  { day: "Sáb", value: 100 },
  { day: "Dom", value: 72 },
];
const topProducts = [
  { name: "La Bestia", sales: 124, pct: 100 },
  { name: "Smoky BBQ", sales: 98, pct: 79 },
  { name: "Royal Cheese", sales: 87, pct: 70 },
  { name: "Papas Loaded", sales: 76, pct: 61 },
  { name: "Coca-Cola 600ml", sales: 65, pct: 52 },
];

// --- Sales panel data ---
const salesRows = [
  { folio: "V-00128", fecha: "Hoy 14:32", cajero: "Ana L.", total: "$547.00", pago: "Tarjeta", estado: "Completada" },
  { folio: "V-00127", fecha: "Hoy 14:18", cajero: "Carlos M.", total: "$289.00", pago: "Efectivo", estado: "Completada" },
  { folio: "V-00126", fecha: "Hoy 14:05", cajero: "Sofía R.", total: "$412.00", pago: "Transferencia", estado: "Completada" },
  { folio: "V-00125", fecha: "Hoy 13:54", cajero: "Ana L.", total: "$189.00", pago: "Efectivo", estado: "Completada" },
  { folio: "V-00124", fecha: "Hoy 13:37", cajero: "Carlos M.", total: "$378.00", pago: "Tarjeta", estado: "Cancelada" },
  { folio: "V-00123", fecha: "Hoy 13:20", cajero: "Sofía R.", total: "$658.00", pago: "Efectivo", estado: "Completada" },
];

// --- Cash panel data ---
const cashMovements = [
  { tipo: "Apertura", monto: "+$2,000.00", hora: "08:00", color: "text-emerald-500" },
  { tipo: "Venta V-00123", monto: "+$658.00", hora: "13:20", color: "text-emerald-500" },
  { tipo: "Venta V-00125", monto: "+$189.00", hora: "13:54", color: "text-emerald-500" },
  { tipo: "Retiro caja", monto: "−$500.00", hora: "14:02", color: "text-primary" },
  { tipo: "Venta V-00127", monto: "+$289.00", hora: "14:18", color: "text-emerald-500" },
];

// --- Branches panel data ---
const branches = [
  { name: "Sucursal Centro", code: "CEN", address: "Blvd. Hidalgo 1234", active: true, sales: 24, stock: "98%" },
  { name: "Sucursal Norte", code: "NOR", address: "Av. Tamaulipas 567", active: true, sales: 18, stock: "85%" },
  { name: "Sucursal Sur", code: "SUR", address: "Calz. Revolución 890", active: true, sales: 12, stock: "72%" },
  { name: "Aeropuerto", code: "AER", address: "Terminal 2, Local 23", active: false, sales: 0, stock: "—" },
];

// --- Products panel data ---
const productsRows = [
  { img: "/images/burger-bestia.png", name: "La Bestia", sku: "BRG-001", price: "$189.00", stock: 24, cat: "Burgers" },
  { img: "/images/burger-smoky.png", name: "Smoky BBQ", sku: "BRG-002", price: "$169.00", stock: 8, cat: "Burgers", low: true },
  { img: "/images/burger-royal.png", name: "Royal Cheese", sku: "BRG-003", price: "$159.00", stock: 15, cat: "Burgers" },
  { img: "/images/coca-cola.jpg", name: "Coca-Cola 600ml", sku: "BEV-001", price: "$35.00", stock: 48, cat: "Bebidas" },
];

// --- Categories panel data ---
const categoriesGrid = [
  { name: "Hamburguesas", slug: "burgers", count: 12, color: "bg-primary/20 text-primary" },
  { name: "Bebidas", slug: "drinks", count: 8, color: "bg-blue-500/20 text-blue-600" },
  { name: "Extras", slug: "extras", count: 6, color: "bg-yellow/30 text-yellow-dark" },
  { name: "Postres", slug: "desserts", count: 4, color: "bg-purple-500/20 text-purple-600" },
  { name: "Combos", slug: "combos", count: 5, color: "bg-emerald-500/20 text-emerald-600" },
  { name: "Ensaladas", slug: "salads", count: 3, color: "bg-green-500/20 text-green-600" },
];

// --- Inventory panel data ---
const inventoryRows = [
  { name: "La Bestia", branch: "Centro", stock: 24, min: 10, status: "OK" },
  { name: "Smoky BBQ", branch: "Centro", stock: 8, min: 10, status: "BAJO" },
  { name: "Royal Cheese", branch: "Centro", stock: 15, min: 10, status: "OK" },
  { name: "La Bestia", branch: "Norte", stock: 6, min: 10, status: "BAJO" },
  { name: "Coca-Cola 600ml", branch: "Centro", stock: 48, min: 20, status: "OK" },
  { name: "Papas Loaded", branch: "Sur", stock: 2, min: 15, status: "CRITICO" },
];

// --- Users panel data ---
const usersRows = [
  { initial: "A", name: "Ana López", email: "ana@burger.mx", role: "Administrador", roleColor: "bg-primary text-white", color: "bg-primary", branches: "Todas" },
  { initial: "C", name: "Carlos Martín", email: "carlos@burger.mx", role: "Supervisor", roleColor: "bg-blue-500 text-white", color: "bg-blue-500", branches: "Centro" },
  { initial: "S", name: "Sofía Ramírez", email: "sofia@burger.mx", role: "Cajero", roleColor: "bg-emerald-500 text-white", color: "bg-emerald-500", branches: "Centro" },
  { initial: "J", name: "Jorge Peña", email: "jorge@burger.mx", role: "Cajero", roleColor: "bg-emerald-500 text-white", color: "bg-emerald-500", branches: "Norte" },
];
---

<section id="dashboard" class="bg-cream py-20 lg:py-28">
  <div class="container mx-auto px-4 lg:px-8">
    <SectionHeading
      title="Toma decisiones con datos al día"
      subtitle="Entra a cualquier sección del sistema aquí mismo. Cambia entre vistas, explora tus métricas y prueba el modo claro u oscuro."
    />

    <!-- Desktop mockup with sidebar -->
    <div class="max-w-6xl mx-auto">
      <div id="sistema-dashboard-mock" data-theme="light" class="rounded-2xl border border-gray-200 bg-white shadow-2xl overflow-hidden">
        <!-- Browser chrome -->
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-100 bg-gray-50">
          <div class="flex items-center gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-400"></div>
          </div>
          <div class="bg-white border border-gray-200 rounded-md px-3 py-0.5 text-[10px] text-gray-400 font-mono truncate">
            pos.burgerhouse.mx/<span data-dash-path>dashboard</span>
          </div>
          <div class="w-12"></div>
        </div>

        <div class="grid grid-cols-[170px_1fr] md:grid-cols-[210px_1fr]">
          <!-- Sidebar -->
          <aside class="bg-[#0f0f0f] p-3 space-y-3 sidebar-fade-in flex flex-col min-h-[520px]">
            <div class="flex items-center gap-2 px-2 pb-3 border-b border-white/5">
              <div class="w-8 h-8 rounded-lg bg-yellow flex items-center justify-center shrink-0">
                <Flame class="w-4 h-4 text-dark" />
              </div>
              <div class="min-w-0">
                <p class="text-white text-[11px] font-bold truncate">BurgerHouse</p>
                <p class="text-white/40 text-[9px] truncate">Sucursal Centro</p>
              </div>
            </div>

            {navSections.map((section) => (
              <div>
                <p class="text-white/30 text-[8px] uppercase font-bold tracking-widest mb-1.5 px-2">
                  {section.title}
                </p>
                <div class="space-y-0.5">
                  {section.items.map((item) => (
                    <button
                      type="button"
                      data-dash-nav={item.id}
                      class="dash-nav w-full flex items-center gap-2 px-2 py-1.5 rounded-md text-[10px] font-medium transition-colors text-white/60 hover:text-white hover:bg-white/5 text-left"
                    >
                      <item.icon class="w-3 h-3 shrink-0" />
                      <span class="truncate">{item.title}</span>
                    </button>
                  ))}
                </div>
              </div>
            ))}

            <div class="pt-3 border-t border-white/5 mt-auto">
              <div class="flex items-center gap-2 px-2 py-1.5">
                <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-white text-[9px] font-bold">A</div>
                <div class="min-w-0 flex-1">
                  <p class="text-white text-[10px] font-semibold truncate">Ana López</p>
                  <p class="text-white/40 text-[8px] truncate">Administrador</p>
                </div>
              </div>
            </div>
          </aside>

          <!-- Main area (themeable) -->
          <div
            data-dash-main
            class="bg-[var(--dash-bg)] text-[var(--dash-text)] min-h-[520px] flex flex-col transition-colors duration-300"
          >
            <!-- Top bar -->
            <div class="flex items-center justify-between px-5 py-3 border-b border-[var(--dash-border)] bg-[var(--dash-card)] transition-colors">
              <div>
                <p class="text-[11px] text-[var(--dash-muted)] font-medium">Panel principal</p>
                <p data-dash-title class="text-sm font-bold">Dashboard</p>
              </div>
              <div class="flex items-center gap-2">
                <div class="hidden sm:flex items-center gap-1.5 bg-[var(--dash-subtle)] rounded-lg px-2 py-1 border border-[var(--dash-border)]">
                  <Search class="w-3 h-3 text-[var(--dash-muted)]" />
                  <span class="text-[10px] text-[var(--dash-muted)]">Buscar...</span>
                </div>
                <button
                  type="button"
                  data-dash-theme
                  aria-label="Cambiar tema"
                  title="Cambiar tema"
                  class="w-7 h-7 rounded-lg bg-[var(--dash-subtle)] hover:bg-[var(--dash-border)] border border-[var(--dash-border)] flex items-center justify-center transition-colors"
                >
                  <Sun class="w-3.5 h-3.5 theme-icon-light" />
                  <Moon class="w-3.5 h-3.5 theme-icon-dark hidden" />
                </button>
                <div class="relative">
                  <Bell class="w-4 h-4 text-[var(--dash-muted)]" />
                  <span class="absolute -top-1 -right-1 w-2 h-2 bg-primary rounded-full"></span>
                </div>
              </div>
            </div>

            <!-- Panels container -->
            <div class="flex-1 p-5">

              <!-- DASHBOARD panel -->
              <div data-dash-panel="dashboard">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
                  {statCards.map(({ icon: Icon, label, value, prefix, decimals, change, color }) => (
                    <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-3 shadow-sm stat-card">
                      <div class="flex items-center justify-between mb-1.5">
                        <span class="text-[9px] text-[var(--dash-muted)] font-bold uppercase tracking-wider truncate">{label}</span>
                        <Icon class:list={["w-3.5 h-3.5 shrink-0", color]} />
                      </div>
                      <p
                        class="text-lg font-bold count-up"
                        data-count-up
                        data-target={value}
                        data-prefix={prefix ?? ""}
                        data-decimals={decimals ?? 0}
                      >
                        {prefix ?? ""}0
                      </p>
                      {change && <span class="text-[9px] text-emerald-500 font-semibold">{change} vs ayer</span>}
                    </div>
                  ))}
                </div>

                <div class="grid md:grid-cols-5 gap-4">
                  <div class="md:col-span-3 rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-4 shadow-sm">
                    <div class="flex items-center justify-between mb-3">
                      <p class="text-xs font-bold">Ventas últimos 7 días</p>
                      <button class="text-[10px] text-[var(--dash-muted)] flex items-center gap-1">
                        Esta semana <ChevronDown class="w-3 h-3" />
                      </button>
                    </div>
                    <div class="flex items-end gap-2 h-32">
                      {chartDays.map((d, i) => (
                        <div class="flex-1 flex flex-col items-center gap-1 min-w-0">
                          <div
                            class="w-full rounded-t-md bg-gradient-to-t from-primary to-primary/60 bar-grow"
                            style={`--bar-h: ${d.value * 1.2}px; animation-delay: ${i * 80}ms;`}
                          ></div>
                          <span class="text-[9px] text-[var(--dash-muted)]">{d.day}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                  <div class="md:col-span-2 rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-4 shadow-sm">
                    <p class="text-xs font-bold mb-3">Productos estrella</p>
                    <div class="space-y-2.5">
                      {topProducts.map((p, i) => (
                        <div>
                          <div class="flex items-center justify-between mb-0.5">
                            <span class="text-[10px] font-medium flex items-center gap-1.5 min-w-0">
                              <span class:list={["w-4 h-4 rounded text-[9px] font-bold flex items-center justify-center shrink-0", i === 0 ? "bg-yellow text-dark" : "bg-[var(--dash-subtle)] text-[var(--dash-muted)]"]}>
                                {i + 1}
                              </span>
                              <span class="truncate">{p.name}</span>
                            </span>
                            <span class="text-[9px] text-[var(--dash-muted)] shrink-0 ml-1">{p.sales} uds</span>
                          </div>
                          <div class="h-1.5 rounded-full bg-[var(--dash-subtle)] overflow-hidden">
                            <div
                              class:list={["h-full rounded-full bar-fill", i === 0 ? "bg-yellow" : "bg-primary/60"]}
                              style={`--bar-w: ${p.pct}%; animation-delay: ${600 + i * 100}ms;`}
                            ></div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <!-- POS panel -->
              <div data-dash-panel="pos" class="hidden">
                <div class="flex items-center gap-3 mb-4">
                  <div class="rounded-full bg-primary/10 border border-primary/20 px-3 py-1 text-[10px] font-bold text-primary uppercase tracking-wider">
                    Sucursal Centro · Caja 1
                  </div>
                  <span class="text-[10px] text-[var(--dash-muted)]">Cajero: Ana L.</span>
                </div>
                <div class="grid grid-cols-[1fr_160px] gap-3">
                  <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-3">
                    <div class="flex gap-1.5 mb-3">
                      <span class="px-2 py-0.5 rounded-full bg-primary text-white text-[9px] font-bold">Todas</span>
                      <span class="px-2 py-0.5 rounded-full bg-[var(--dash-subtle)] text-[var(--dash-muted)] text-[9px]">Burgers</span>
                      <span class="px-2 py-0.5 rounded-full bg-[var(--dash-subtle)] text-[var(--dash-muted)] text-[9px]">Bebidas</span>
                    </div>
                    <div class="grid grid-cols-3 gap-2">
                      {[
                        { img: "/images/burger-bestia.png", name: "La Bestia", price: "$189" },
                        { img: "/images/burger-smoky.png", name: "Smoky BBQ", price: "$169" },
                        { img: "/images/burger-royal.png", name: "Royal Cheese", price: "$159" },
                        { img: "/images/coca-cola.jpg", name: "Coca-Cola", price: "$35" },
                        { img: "/images/burger-bestia.png", name: "Bestia Doble", price: "$229" },
                        { img: "/images/burger-smoky.png", name: "Smoky Jr.", price: "$129" },
                      ].map((p) => (
                        <div class="rounded-lg bg-[var(--dash-subtle)] border border-[var(--dash-border)] overflow-hidden">
                          <div class="aspect-square"><img src={p.img} alt={p.name} class="w-full h-full object-cover" loading="lazy" /></div>
                          <div class="px-1.5 py-1">
                            <p class="text-[9px] font-semibold truncate">{p.name}</p>
                            <p class="text-[9px] text-primary font-bold">{p.price}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                  <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-3 flex flex-col">
                    <p class="text-[10px] font-bold uppercase tracking-wider mb-2">Orden</p>
                    <div class="flex-1 space-y-1.5 text-[10px]">
                      <div class="flex justify-between"><span>La Bestia ×2</span><span class="font-bold">$378</span></div>
                      <div class="flex justify-between"><span>Coca-Cola ×1</span><span class="font-bold">$35</span></div>
                    </div>
                    <div class="border-t border-[var(--dash-border)] pt-2 mt-2 flex justify-between text-xs font-bold">
                      <span>Total</span><span class="text-primary">$479.28</span>
                    </div>
                    <button class="mt-2 w-full py-1.5 rounded-lg bg-primary text-white text-[10px] font-bold">Cobrar</button>
                  </div>
                </div>
                <p class="mt-4 text-center text-[11px] text-[var(--dash-muted)]">
                  👇 Pruébalo de verdad más abajo, en la sección de demo.
                </p>
              </div>

              <!-- SALES panel -->
              <div data-dash-panel="sales" class="hidden">
                <div class="flex items-center gap-2 mb-3">
                  <button class="inline-flex items-center gap-1 bg-[var(--dash-subtle)] border border-[var(--dash-border)] rounded-lg px-2.5 py-1 text-[10px]">
                    <Filter class="w-3 h-3" /> Filtros
                  </button>
                  <button class="inline-flex items-center gap-1 bg-[var(--dash-subtle)] border border-[var(--dash-border)] rounded-lg px-2.5 py-1 text-[10px]">
                    Hoy <ChevronDown class="w-3 h-3" />
                  </button>
                  <button class="ml-auto inline-flex items-center gap-1 bg-emerald-500 text-white rounded-lg px-2.5 py-1 text-[10px] font-bold">
                    <Download class="w-3 h-3" /> CSV
                  </button>
                </div>
                <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] overflow-hidden">
                  <div class="grid grid-cols-6 gap-2 px-3 py-2 border-b border-[var(--dash-border)] text-[9px] font-bold uppercase tracking-wider text-[var(--dash-muted)]">
                    <span>Folio</span><span>Fecha</span><span>Cajero</span><span>Total</span><span>Pago</span><span>Estado</span>
                  </div>
                  {salesRows.map((r) => (
                    <div class="grid grid-cols-6 gap-2 px-3 py-2 border-b border-[var(--dash-border)] text-[10px] items-center last:border-0">
                      <span class="font-mono font-semibold">{r.folio}</span>
                      <span class="text-[var(--dash-muted)]">{r.fecha}</span>
                      <span>{r.cajero}</span>
                      <span class="font-bold text-primary">{r.total}</span>
                      <span>{r.pago}</span>
                      <span>
                        <span class:list={["inline-block px-1.5 py-0.5 rounded-full text-[8px] font-bold",
                          r.estado === "Completada" ? "bg-emerald-500/20 text-emerald-600" : "bg-primary/20 text-primary"]}>
                          {r.estado}
                        </span>
                      </span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- CASH panel -->
              <div data-dash-panel="cash" class="hidden">
                <div class="grid md:grid-cols-4 gap-3 mb-4">
                  <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-3">
                    <p class="text-[9px] text-[var(--dash-muted)] uppercase font-bold">Esperado</p>
                    <p class="text-lg font-bold">$12,450.00</p>
                  </div>
                  <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] p-3">
                    <p class="text-[9px] text-[var(--dash-muted)] uppercase font-bold">Contado</p>
                    <p class="text-lg font-bold">$12,400.00</p>
                  </div>
                  <div class="rounded-xl border border-primary/30 bg-primary/5 p-3">
                    <p class="text-[9px] text-primary uppercase font-bold">Diferencia</p>
                    <p class="text-lg font-bold text-primary">−$50.00</p>
                  </div>
                  <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/5 p-3 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <div>
                      <p class="text-[9px] text-emerald-600 uppercase font-bold">Estado</p>
                      <p class="text-sm font-bold text-emerald-600">Caja abierta</p>
                    </div>
                  </div>
                </div>
                <div class="rounded-xl border border-[var(--dash-border)] bg-[var(--dash-card)] overflow-hidden">
                  <p class="text-xs font-bold px-3 py-2 border-b border-[var(--dash-border)]">Movimientos recientes</p>
                  {cashMovements.map((m) => (
                    <div class="flex items-center justify-between px-3 py-2 border-b border-[var(--dash-border)] text-[11px] last:border-0">
                      <div class="flex items-center gap-2">
                        {m.color === "text-emerald-500"
                          ? <ArrowUpRight class="w-3.5 h-3.5 text-emerald-500" />
