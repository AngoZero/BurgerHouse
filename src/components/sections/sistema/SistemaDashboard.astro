<style>
  /* Light/dark theme variables for the dashboard mockup */
  #sistema-dashboard-mock [data-dash-main] {
    --dash-bg: #fafafa;
    --dash-card: #ffffff;
    --dash-subtle: #f4f4f5;
    --dash-border: #e5e7eb;
    --dash-text: #1a1a1a;
    --dash-muted: #6b7280;
  }
  #sistema-dashboard-mock[data-theme="dark"] [data-dash-main] {
    --dash-bg: #0a0a0a;
    --dash-card: #141414;
    --dash-subtle: #1f1f1f;
    --dash-border: rgba(255, 255, 255, 0.08);
    --dash-text: #f5f5f5;
    --dash-muted: rgba(255, 255, 255, 0.5);
  }

  @keyframes sidebarFadeIn {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes barGrow {
    from { height: 0; }
    to { height: var(--bar-h); }
  }
  @keyframes barFill {
    from { width: 0; }
    to { width: var(--bar-w); }
  }
  @keyframes statCardIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .sidebar-fade-in { animation: sidebarFadeIn 0.5s ease-out both; }
  .bar-grow { height: 0; animation: barGrow 900ms cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .bar-fill { width: 0; animation: barFill 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .stat-card { opacity: 0; animation: statCardIn 500ms ease-out forwards; }
  .stat-card:nth-child(1) { animation-delay: 80ms; }
  .stat-card:nth-child(2) { animation-delay: 180ms; }
  .stat-card:nth-child(3) { animation-delay: 280ms; }
  .stat-card:nth-child(4) { animation-delay: 380ms; }
</style>

<script>
  const mock = document.getElementById("sistema-dashboard-mock");
  if (mock) {
    const navBtns = mock.querySelectorAll<HTMLButtonElement>("[data-dash-nav]");
    const panels = mock.querySelectorAll<HTMLDivElement>("[data-dash-panel]");
    const titleEl = mock.querySelector<HTMLElement>("[data-dash-title]");
    const pathEl = mock.querySelector<HTMLElement>("[data-dash-path]");
    const themeBtn = mock.querySelector<HTMLButtonElement>("[data-dash-theme]");
    const iconLight = mock.querySelector<SVGElement>(".theme-icon-light");
    const iconDark = mock.querySelector<SVGElement>(".theme-icon-dark");

    const labels: Record<string, string> = {
      dashboard: "Dashboard",
      pos: "Punto de venta",
      sales: "Ventas",
      cash: "Caja",
      branches: "Sucursales",
      products: "Productos",
      categories: "Categorías",
      inventory: "Inventario",
      reports: "Reportes",
      users: "Usuarios",
      company: "Empresa",
    };

    function setActive(moduleId: string): void {
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.dashPanel !== moduleId));
      navBtns.forEach((b) => {
        const active = b.dataset.dashNav === moduleId;
        b.classList.toggle("bg-primary", active);
        b.classList.toggle("text-white", active);
        b.classList.toggle("shadow-sm", active);
        b.classList.toggle("text-white/60", !active);
      });
      if (titleEl) titleEl.textContent = labels[moduleId] ?? "";
      if (pathEl) pathEl.textContent = moduleId === "dashboard" ? "dashboard" : moduleId;
    }

    navBtns.forEach((btn) => {
      btn.addEventListener("click", () => setActive(btn.dataset.dashNav ?? "dashboard"));
    });

    // Theme toggle persisted in localStorage
    const THEME_KEY = "burgerhouse-dash-theme";
    const storedTheme = (typeof localStorage !== "undefined" && localStorage.getItem(THEME_KEY)) || "light";
    applyTheme(storedTheme);

    themeBtn?.addEventListener("click", () => {
      const current = mock.dataset.theme === "dark" ? "dark" : "light";
      const next = current === "dark" ? "light" : "dark";
      applyTheme(next);
      try {
        localStorage.setItem(THEME_KEY, next);
      } catch {
        /* ignore */
      }
    });

    function applyTheme(theme: string): void {
      mock!.dataset.theme = theme;
      iconLight?.classList.toggle("hidden", theme === "dark");
      iconDark?.classList.toggle("hidden", theme !== "dark");
    }

    setActive("dashboard");
  }

  // Count-up animation when stats enter the viewport (runs once).
  const countEls = document.querySelectorAll<HTMLElement>("[data-count-up]");
  if (countEls.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseFloat(el.dataset.target ?? "0");
          const prefix = el.dataset.prefix ?? "";
          const decimals = parseInt(el.dataset.decimals ?? "0", 10);
          const duration = 1400;
          const startTs = performance.now();
          const tick = (now: number) => {
            const progress = Math.min((now - startTs) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = target * eased;
            el.textContent = prefix + current.toLocaleString("es-MX", {
              minimumFractionDigits: decimals,
              maximumFractionDigits: decimals,
            });
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          observer.unobserve(el);
        });
      },
      { threshold: 0.3 }
    );
    countEls.forEach((el) => observer.observe(el));
  }
</script>
