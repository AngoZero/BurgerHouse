---
import { Shield, Check } from "lucide-astro";
import { roles } from "../../../data/sistema";
import SectionHeading from "../../ui/SectionHeading.astro";
---

<section id="roles" class="bg-dark py-20 lg:py-28">
  <div class="container mx-auto px-4 lg:px-8">
    <SectionHeading
      title="Cada quien en su lugar"
      subtitle="Define qué puede ver y hacer cada persona de tu equipo. Tus cajeros solo ven su sucursal, tus supervisores gestionan lo suyo, y tú tienes la visión completa."
      light
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-4xl mx-auto">
      {roles.map((role, i) => (
        <div
          data-reveal="fade-up"
          data-reveal-delay={i * 140}
          class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-5 hover:border-white/20 transition-colors"
        >
          <div class="flex items-center gap-2.5 mb-4">
            <Shield class="w-5 h-5 text-yellow" />
            <h3 class="text-white font-bold text-sm">{role.name}</h3>
          </div>

          <span class:list={["inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold mb-4", role.badgeColor]}>
            {role.badge}
          </span>

          <ul class="space-y-2">
            {role.permissions.map((perm) => (
              <li class="flex items-start gap-2">
                <Check class="w-3.5 h-3.5 text-yellow mt-0.5 shrink-0" />
                <span class="text-white/70 text-xs leading-relaxed">{perm}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-white/40 text-sm max-w-xl mx-auto">
        Tu equipo entra con usuario y contraseña. Nadie puede ver información de sucursales
        que no le corresponden, y tú puedes agregar o dar de baja personas cuando quieras.
      </p>
    </div>
  </div>
</section>
