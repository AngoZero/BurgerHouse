---
interface Props {
  title: string;
  subtitle?: string;
  light?: boolean;
}

const { title, subtitle, light = false } = Astro.props;
---

<div class="text-center mb-12 lg:mb-16">
  <h2
    class:list={[
      "text-4xl md:text-5xl lg:text-6xl font-display tracking-wide mb-4",
      light ? "text-white" : "text-dark",
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={[
          "text-lg max-w-2xl mx-auto",
          light ? "text-text-muted" : "text-text-secondary",
        ]}
      >
        {subtitle}
      </p>
    )
  }
</div>
