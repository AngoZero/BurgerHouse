---
interface Props {
  variant?: "primary" | "outline" | "yellow";
  href?: string;
  class?: string;
}

const { variant = "primary", href, class: className } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center px-8 py-3.5 rounded-full font-bold text-sm uppercase tracking-wider transition-all duration-300 cursor-pointer";

const variantClasses = {
  primary: "bg-primary text-white hover:bg-primary-hover shadow-lg hover:shadow-xl hover:scale-105",
  yellow: "bg-yellow text-dark hover:bg-yellow-dark shadow-lg hover:shadow-xl hover:scale-105",
  outline: "border-2 border-white text-white hover:bg-white hover:text-dark",
};

const classes = `${baseClasses} ${variantClasses[variant]} ${className ?? ""}`;
const Tag = href ? "a" : "button";
---

<Tag href={href} class={classes}>
  <slot />
</Tag>
